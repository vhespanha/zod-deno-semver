{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "version": "0.0.1",
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "always",
    "exclude": ["**/logs.json"]
  },
  "imports": {
    "@std/semver": "jsr:@std/semver@^1.0.8",
    "@zod/zod": "jsr:@zod/zod@^4.3.6"
  }
}
